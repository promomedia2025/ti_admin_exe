{
  "name": "Promo-Media",
  "version": "1.4.4",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "publish": "electron-builder --win --publish always",
    "publish:dry-run": "electron-builder --win --publish never",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "pdf-to-printer": "^5.6.1",
    "sound-play": "^1.1.0"
  },
  "build": {
    "appId": "com.promomedia.app",
    "productName": "Promo-Media",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "promomedia2025",
      "repo": "ti_admin_exe",
      "private": true
    },
    "files": [
      "**/*",
      "phone-ringtone-normal-444775.mp3",
      "!node_modules/electron-builder/**/*",
      "!node_modules/@electron/**/*"
    ]
  }
}
